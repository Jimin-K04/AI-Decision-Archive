<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="CategoryButtonStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">6dp</item>
        <item name="android:background">@drawable/category_button_selector</item>
        <item name="backgroundTint">@android:color/transparent</item>        <item name="android:gravity">center</item>
        <item name="android:maxLines">1</item>
        <item name="android:paddingHorizontal">10dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@drawable/category_text_selector</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="EmojiStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_margin">3dp</item>
        <item name="android:textSize">26sp</item>
    </style>

</resources>