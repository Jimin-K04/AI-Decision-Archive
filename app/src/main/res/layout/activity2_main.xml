<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF7F1"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="28dp"
        android:paddingEnd="20dp"
        android:paddingBottom="36dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI 결정 분석"
            android:textColor="#2B1712"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="방금 남긴 결정을 감정, 날씨와 함께 살펴봤어요."
            android:textColor="#7E6A5D"
            android:textSize="16sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="22dp"
            android:background="#E8D8CA" />

        <!-- 상단 요약 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/activity2_bg_hero"
            android:elevation="5dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="오늘의 결정 상태"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStateSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="AI가 오늘의 상태를 요약하고 있어요."
                android:textColor="#FFF6EF"
                android:textSize="15sp"
                android:lineSpacingExtra="5dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvChipCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/activity2_bg_chip"
                    android:paddingStart="13dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="13dp"
                    android:paddingBottom="6dp"
                    android:text="일상"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvChipStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/activity2_bg_chip"
                    android:paddingStart="13dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="13dp"
                    android:paddingBottom="6dp"
                    android:text="분석 중"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvChipWeather"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/activity2_bg_chip"
                    android:paddingStart="13dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="13dp"
                    android:paddingBottom="6dp"
                    android:text="날씨"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </LinearLayout>

        <!-- 의사결정 프로파일 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:background="@drawable/activity2_bg_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="의사결정 프로파일"
                android:textColor="#2B1712"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDecisionSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="결정 기록 요약"
                android:textColor="#7E6A5D"
                android:textSize="14sp"
                android:lineSpacingExtra="5dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="감정 비율"
                android:textColor="#7E6A5D"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvEmotionValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="0%"
                android:textColor="#2B1712"
                android:textSize="15sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/progressEmotion"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="4dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#FF6673"
                android:progressBackgroundTint="#F2ECE4" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="논리 비율"
                android:textColor="#7E6A5D"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvLogicValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="0%"
                android:textColor="#2B1712"
                android:textSize="15sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/progressLogic"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="4dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#11A6C8"
                android:progressBackgroundTint="#F2ECE4" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="리스크 감수"
                android:textColor="#7E6A5D"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvRiskValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="0점"
                android:textColor="#2B1712"
                android:textSize="15sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/progressRisk"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="4dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#F58A00"
                android:progressBackgroundTint="#F2ECE4" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="선택 근거"
                android:textColor="#7E6A5D"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvReasonValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="0점"
                android:textColor="#2B1712"
                android:textSize="15sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/progressReason"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="4dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#D94D8C"
                android:progressBackgroundTint="#F2ECE4" />

        </LinearLayout>

        <!-- 상세 분석 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/activity2_bg_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="분석 메모"
                android:textColor="#2B1712"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDecisionType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="💞 결정 유형"
                android:textColor="#2B1712"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="#EFE3D8" />

            <TextView
                android:id="@+id/tvDecisionStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🧠 결정 성향"
                android:textColor="#2B1712"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="#EFE3D8" />

            <TextView
                android:id="@+id/tvRiskScore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚖️ 리스크 감수 성향"
                android:textColor="#2B1712"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="#EFE3D8" />

            <TextView
                android:id="@+id/tvReasonScore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📝 선택 근거 점수"
                android:textColor="#2B1712"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="#EFE3D8" />

            <TextView
                android:id="@+id/tvRegretPrediction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔮 후회 가능성"
                android:textColor="#2B1712"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp" />

        </LinearLayout>

        <!-- 날씨 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/activity2_bg_soft_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="☁️ 오늘의 날씨와 감정"
                android:textColor="#2B1712"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWeatherRelation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="날씨와 감정 분석"
                android:textColor="#3F2D24"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp" />

        </LinearLayout>

        <!-- 조언 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/activity2_bg_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🌿 오늘의 조언"
                android:textColor="#2B1712"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAdvice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="버튼을 누르면 오늘의 조언이 표시됩니다."
                android:textColor="#7E6A5D"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShowAdvice"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="18dp"
                android:text="오늘의 조언 열기"
                android:textAllCaps="false"
                android:textColor="#2B1712"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#FFFEFC"
                app:cornerRadius="18dp"
                app:strokeColor="#E8D8CA"
                app:strokeWidth="1dp" />

        </LinearLayout>

        <!-- 하단 버튼 -->
        <LinearLayout
            android:id="@+id/bottomButtonLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNewDecision"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="새 결정"
                android:textAllCaps="false"
                android:textColor="#2B1712"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#FFFEFC"
                app:cornerRadius="18dp"
                app:strokeColor="#E8D8CA"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTimeCapsule"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="타임캡슐로"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#D95B3D"
                app:cornerRadius="18dp"
                app:rippleColor="#FBE1D8" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>